import { Router, Route } from 'src/router/ripple-router';

import { ProductsPage, ProductDescriptionPage } from 'src/router/routes.ripple';

component RouterProvider() {
  <Router>
    <Route path="/:productId" element={ProductDescriptionPage} />
    <Route path="/" element={ProductsPage} />
  </Router>
}

export { RouterProvider };
